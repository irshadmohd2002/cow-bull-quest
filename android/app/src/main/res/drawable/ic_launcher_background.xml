<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon background layer: a radial navy-to-royal-blue gradient
     matching assets/branding/cow_bull_quest_icon.png's own backdrop, kept
     as a vector gradient (not a raster PNG) so there is one deterministic
     source and no per-density scaling seams. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="140%"
        android:centerX="0.5"
        android:centerY="0.35"
        android:startColor="#0B4CDA"
        android:centerColor="#12246B"
        android:endColor="#0B1026" />
</shape>
